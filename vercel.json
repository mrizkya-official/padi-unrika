{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/index", "dest": "/api/index.php" },
    { "src": "/profil", "dest": "/api/profil.php" },
    { "src": "/kontak", "dest": "/api/kontak.php" },
    { "src": "/layanan", "dest": "/api/layanan.php" },
    { "src": "/daftar-hadir", "dest": "/api/daftar-hadir.php" },
    { "src": "/referensi", "dest": "/api/referensi.php" },
    { "src": "/", "dest": "/api/index.php" }
  ]
}